# MCP Client - Environment Configuration
# Copy this file to .env and customize the values for your environment

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Application Port (single app serves both frontend and backend)
APP_PORT=8000

# Environment Mode — controls the label shown in the sidebar (e.g. "Production", "Staging", "Development")
# Use APP_ENVIRONMENT for the display label; ENVIRONMENT is the legacy alias (both are read).
APP_ENVIRONMENT=Development
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Authorization Settings
# =============================================================================

# Default tabs accessible to non-admin users (comma-separated list of exact tab names)
DEFAULT_ALLOWED_TABS=Home,Settings

# =============================================================================
# Database Configuration
DATABASE_NAME=mcp_client
DATABASE_USER=nova_user
DATABASE_PASSWORD=NovaNextDevPassword2025!
DATABASE_HOST=postgres
DATABASE_PORT=5432

# Full Database Connection URL (auto-generated from above)
DATABASE_URL=postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production-please-make-it-long-and-random
SECRET_KEY=your-super-secret-jwt-key-change-in-production-please-make-it-long-and-random
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Default admin user for the application
ADMIN_PASSWORD=admin123

# =============================================================================
# SSO / OIDC CONFIGURATION (Authentik)
# =============================================================================
# Uncomment and configure these to enable company SSO login via Authentik.
# When SSO_ENABLED=false only local username/password login is available.

SSO_ENABLED=false

# Authentik OIDC provider URL
# OIDC_ISSUER_URL=https://authentik.company.com/application/o/portal/

# OAuth 2.0 client credentials (from Authentik application configuration)
# OIDC_CLIENT_ID=your-client-id
# OIDC_CLIENT_SECRET=your-client-secret

# Redirect URI — must match what is registered in Authentik
# OIDC_REDIRECT_URI=http://localhost:8000/api/sso/callback

# OIDC scopes (default includes groups for portal authorization)
OIDC_SCOPES=openid email profile groups

# =============================================================================
# MCP SERVER CONFIGURATION (Optional)
# =============================================================================

# External MCP Server (if you have one)
MCP_SERVER_URL=http://localhost:8050/mcp/

# =============================================================================
# LLM CONFIGURATION (Optional)
# =============================================================================

# Uncomment and configure these if you're using external LLM services
# LLM_API_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4
# LLM_API_KEY=your-openai-api-key-here
# LLM_SSL_VERIFY=true

# =============================================================================
# REDIS CONFIGURATION (Optional)
# =============================================================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# =============================================================================
# RESEARCH / IDA MCP CONFIGURATION
# =============================================================================

# Artifactory PyPI Configuration for fetching package versions
ARTIFACTORY_PYPI_REPO="pypi-local"
ARTIFACTORY_PYPI_PACKAGE="ida-pro-mcp"

# The base pip install command prefix. The portal UI will append "==<version>" to this.
PIP_INSTALL_CMD_BASE="pip install my-company-ida-mcp-plugin"

# The OpenWebUI portal URL for users to navigate to
OPENWEBUI_URL="https://chat.company.internal"

# Developer auth portal where users can create LLM API keys and upstream tokens for agents/MCP servers
DEVELOPER_AUTH_PORTAL_URL="https://developer-portal.company.internal"

# The NGINX server DNS for MCP routing
MCP_NGINX_DNS="https://mcp-gateway.company.internal"

# The Infrastructure API server for provisioning MCPs
INFRA_API_SERVER="infra-api.company.internal"

# The Infrastructure API server for Chart deployment/undeployment (Agents and MCPs)
INFRA_CHARTS_API_SERVER="marketplace-infra-api.company.internal"

# =============================================================================
# MARKETPLACE CONFIGURATION
# =============================================================================

# Maximum number of Agents each user can create (admin-controlled)
MARKETPLACE_MAX_AGENTS_PER_USER=5

# Maximum number of MCP Servers each user can create
MARKETPLACE_MAX_MCP_PER_USER=5

# TTL in days for dev-environment deployments before auto-removal
MARKETPLACE_DEV_TTL_DAYS=10

# Artifactory Helm chart repository paths for marketplace entities
# Format: "<repo-name>/<sub-path>" — adjust to match your Artifactory layout
# Artifactory Helm chart repository names for marketplace Helm chart discovery.
# Charts are discovered at:  {repo}/{APP_NAME}/{VERSION}/{APP_NAME}-{VERSION}.tgz
ARTIFACTORY_MARKETPLACE_HELM_REPO_DEV="my-helm-dev-local"
ARTIFACTORY_MARKETPLACE_HELM_REPO_RELEASE="my-helm-release-local"

# Bitbucket URL for the plugin repository
BITBUCKET_IDA_MCP_REPO="https://bitbucket.example.com/projects/RES/repos/ida-pro-mcp"

# Path to the changelog file to display in the UI
CHANGELOG_PATH="CHANGELOG.md"

NGINX_PORT=80

# =============================================================================
# DEVELOPMENT FLAGS
# =============================================================================
DEBUG=true
ENVIRONMENT=development

# =============================================================================
# DOCKER COMPOSE PROFILES
# =============================================================================
# Available profiles:
# - default: postgres + backend + frontend
# - full: includes redis
# - nginx: includes nginx reverse proxy
# - mcp: includes mock MCP server
#
# Usage examples:
# docker-compose up                           # Basic setup
# docker-compose --profile full up           # With Redis
# docker-compose --profile nginx up          # With Nginx
# docker-compose --profile mcp up            # With MCP server
# docker-compose --profile full --profile nginx --profile mcp up  # Everything connection settings
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=mcp_db

# Default admin user for the application
ADMIN_PASSWORD=admin

# MCP Server URL
MCP_SERVER_URL=http://localhost:8050/mcp/
